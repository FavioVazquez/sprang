{
  "permissions": {
    "allow": [
      "Bash(npx @faviovazquez/sprang*)",
      "Bash(node packages/mcp/dist/server.js*)",
      "Bash(pnpm --filter @sprang/dashboard dev*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git rev-parse*)",
      "Bash(cat .sprang/agent-conversation.md*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [".claude/hooks/post-tool-use.sh"]
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [".claude/hooks/session-start.sh"]
          }
        ]
      }
    ]
  }
}
