    "micromatch": "^4.0.8",
    "object-hash": "^3.0.0",
    "p-queue": "^8.0.1",
    "simple-git": "^3.27.0",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/object-hash": "^3.0.6",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
