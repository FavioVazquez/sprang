{
  "name": "@sprang/dashboard",
  "version": "0.2.2",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsup src/server/standalone.ts --format esm --no-dts --sourcemap --platform node --target node22 --outDir dist",
    "build:server": "tsup src/server/standalone.ts --format esm --no-dts --sourcemap --platform node --target node22 --outDir dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright install chromium && playwright test",
    "test:e2e:bridge": "playwright test --config playwright.bridge.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@xyflow/react": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "elkjs": "^0.9.3",
    "framer-motion": "^11.11.17",
    "fuse.js": "^7.0.0",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "lucide-react": "^0.469.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph": "^1.48.2",
    "sigma": "^3.0.0",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
